# Copy to `backend/.env` and fill in real values. `.env` is gitignored; this file is not.
# The backend reads these via pydantic-settings (src/lsap/config.py).

# Claude API key — the rater (M1+) and the engine (M4) call the Anthropic API.
# Same variable the `anthropic` SDK reads by default.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides (defaults live in config.py; see the claude-api skill for IDs).
# RATER_MODEL=claude-opus-4-8
# SECOND_RATER_MODEL=claude-haiku-4-5
